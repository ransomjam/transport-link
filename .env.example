# Copy these values into the app-specific .env files before running locally or
# into Render environment variables for deployment.

DATABASE_URL=
JWT_SECRET=
FRONTEND_URL=
NODE_ENV=production
PORT=4000
NEXT_PUBLIC_API_URL=

# Road-routing server (OSRM-compatible). Default is the public demo server;
# self-host for production. Routes fall back to a direct line if unreachable.
OSRM_URL="https://router.project-osrm.org"
ROUTE_TIMEOUT_MS=7000
