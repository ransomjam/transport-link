# Copy these values into the app-specific .env files before running locally.

DATABASE_URL="postgresql://postgres:postgres@localhost:55433/goods_tracking?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=4000
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Road-routing server (OSRM-compatible). Default is the public demo server;
# self-host for production. Routes fall back to a direct line if unreachable.
OSRM_URL="https://router.project-osrm.org"
ROUTE_TIMEOUT_MS=7000
