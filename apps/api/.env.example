DATABASE_URL=
JWT_SECRET=
FRONTEND_URL=
NODE_ENV=production
PORT=4000

# Road-routing server used to build shipment routes. The default is the public
# OSRM demo server (rate-limited; fine for development). For production, run a
# self-hosted OSRM instance and point this at it. If the server is unreachable,
# routes fall back to a direct geodesic line so tracking never breaks.
OSRM_URL="https://router.project-osrm.org"
ROUTE_TIMEOUT_MS=7000
